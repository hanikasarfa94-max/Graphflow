# WorkGraph AI — environment configuration example
# Copy this to .env and fill in real values. The api + worker will fail fast
# with a clear error if any of these are missing (see Phase 1 env loader).

# --- API app ---
WORKGRAPH_ENV=dev                   # dev | staging | prod
WORKGRAPH_API_HOST=127.0.0.1
WORKGRAPH_API_PORT=8000
WORKGRAPH_LOG_LEVEL=INFO

# --- Database (Postgres) — not used yet in Phase 1; wired in Phase 2+ ---
# WORKGRAPH_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/workgraph

# --- Redis / Celery — not used yet in Phase 1; wired in Phase 6+ ---
# WORKGRAPH_REDIS_URL=redis://localhost:6379/0

# --- LLM (Anthropic) — not used yet in Phase 1; wired in Phase 3 ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Feishu — not used yet in Phase 1; wired in Phase 2/7 ---
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
