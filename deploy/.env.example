# WorkGraph AI — deploy env. Copy to `.env` next to docker-compose.yml
# and fill in the real values. Docker compose reads `.env` automatically.

# ---- Required ---------------------------------------------------------------

# DeepSeek API key. Keep blank to run in dev/stub mode (no LLM calls).
DEEPSEEK_API_KEY=

# ---- Optional ---------------------------------------------------------------

WORKGRAPH_ENV=prod
WORKGRAPH_LOG_LEVEL=INFO

# SQLite on a Docker volume is fine for single-node. Swap to Postgres by
# setting e.g. postgresql+asyncpg://user:pass@pg:5432/workgraph and adding
# a postgres service to docker-compose.yml.
WORKGRAPH_DATABASE_URL=sqlite+aiosqlite:////data/workgraph.db
